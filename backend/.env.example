# ─────────────────────────────────────────────────────────────────────────────
# IncidentIQ backend configuration
#
# All values are optional. When AWS / monitoring keys are absent, the backend
# runs in DEMO MODE with realistic seeded data. This lets you trial every
# feature without provisioning any cloud accounts.
# ─────────────────────────────────────────────────────────────────────────────

# AWS Bedrock — Amazon Nova Pro
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=amazon.nova-pro-v1:0

# Datadog
DATADOG_API_KEY=
DATADOG_APP_KEY=
DATADOG_SITE=datadoghq.com

# Grafana
GRAFANA_URL=
GRAFANA_API_KEY=

# New Relic
NEW_RELIC_USER_KEY=
NEW_RELIC_ACCOUNT_ID=

# Slack — incoming webhook URL for auto-posting incident analyses
SLACK_WEBHOOK_URL=

# Server
PORT=8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
LOG_LEVEL=INFO
